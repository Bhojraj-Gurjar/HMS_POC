{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "DataMode": {
    "Mode": "Mock",
    "AllowMockFallback": true
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=HMS_PatientRegistration;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "https://localhost:4200"
    ]
  },
  "Jwt": {
    "Issuer": "HMS.PatientRegistration",
    "Audience": "HMS.PatientRegistration.Client",
    "SecretKey": "REPLACE_WITH_A_SECURE_KEY_AT_LEAST_32_CHARS_LONG",
    "ExpirationMinutes": 60
  }
}
